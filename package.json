{
  "name": "chat-api",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "author": "cobuild",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:drift": "bash scripts/check-agent-docs-drift.sh",
    "docs:gardening": "bash scripts/doc-gardening.sh --fail-on-issues",
    "review:gpt": "cobuild-review-gpt --config scripts/review-gpt.config.sh",
    "wire:status": "pnpm pkg get dependencies.@cobuild/wire",
    "wire:ensure-published": "bash scripts/wire-ensure-published.sh",
    "wire:use-local": "bash scripts/wire-use-local.sh",
    "wire:use-published": "bash scripts/wire-use-published.sh",
    "verify": "pnpm docs:drift && pnpm docs:gardening && pnpm typecheck && pnpm test && pnpm test:coverage",
    "verify:required": "pnpm verify",
    "verify:full": "pnpm verify"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@cobuild/repo-tools": "^0.1.4",
    "@cobuild/review-gpt": "^0.2.11",
    "@tsconfig/recommended": "^1.0.1",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.9",
    "@cobuild/wire": "^0.1.3",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/request-context": "^6.0.2",
    "ai": "^6.0.30",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "viem": "^2.38.5",
    "zod": "^4.1.8"
  },
  "packageManager": "pnpm@9.15.9"
}
